###
# StartupVerse Backend Pagination Test Suite
# Use with REST Client extension in VS Code
# Set @baseUrl to your Express API (same as VITE_API_URL) and @authToken to a valid JWT.
###

@baseUrl = {{$dotenv VITE_API_URL}}
@authToken = Bearer YOUR_JWT

### ============================================
### HEALTH CHECK
### ============================================

### Test 1: Health Check
GET {{baseUrl}}/health
Content-Type: application/json

### ============================================
### FOUNDERS ENDPOINTS (6 tests)
### ============================================

### Test 2: Get All Founders (Paginated)
GET {{baseUrl}}/founders?page=1&pageSize=10
Authorization: {{authToken}}
Content-Type: application/json

### Test 3: Get All Founders (Page 2)
GET {{baseUrl}}/founders?page=2&pageSize=5
Authorization: {{authToken}}
Content-Type: application/json

### Test 4: Get Founder's Invitations
# Replace {founderId} with actual founder ID
GET {{baseUrl}}/founders/{founderId}/invitations?page=1&pageSize=10
Authorization: {{authToken}}
Content-Type: application/json

### Test 5: Get Founder's Tasks (with search)
# Replace {founderId} with actual founder ID
GET {{baseUrl}}/founders/{founderId}/tasks?page=1&pageSize=10&search=test
Authorization: {{authToken}}
Content-Type: application/json

### Test 6: Get Founder's Tasks (with filters)
# Replace {founderId} with actual founder ID
GET {{baseUrl}}/founders/{founderId}/tasks?page=1&pageSize=10&status=in_progress&priority=high
Authorization: {{authToken}}
Content-Type: application/json

### Test 7: Get Founder's Milestones
# Replace {founderId} with actual founder ID
GET {{baseUrl}}/founders/{founderId}/milestones?page=1&pageSize=10
Authorization: {{authToken}}
Content-Type: application/json

### Test 8: Get Founder's Weekly Outcomes
# Replace {founderId} with actual founder ID
GET {{baseUrl}}/founders/{founderId}/weekly-outcomes?page=1&pageSize=10
Authorization: {{authToken}}
Content-Type: application/json

### Test 9: Get Founder's Posts
# Replace {founderId} with actual founder ID
GET {{baseUrl}}/founders/{founderId}/posts?page=1&pageSize=10
Authorization: {{authToken}}
Content-Type: application/json

