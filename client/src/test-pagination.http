# Replace {talentId} with actual talent ID
GET {{baseUrl}}/invitations/received/{talentId}?page=1&pageSize=10
Authorization: {{authToken}}
Content-Type: application/json

### ============================================
### EDGE CASE TESTS
### ============================================

### Test 33: Invalid Page Number (0)
GET {{baseUrl}}/founders?page=0&pageSize=10
Authorization: {{authToken}}
Content-Type: application/json

### Test 34: Invalid Page Number (Negative)
GET {{baseUrl}}/founders?page=-1&pageSize=10
Authorization: {{authToken}}
Content-Type: application/json

### Test 35: Page Beyond Total
GET {{baseUrl}}/founders?page=999999&pageSize=10
Authorization: {{authToken}}
Content-Type: application/json

### Test 36: Large Page Size (should cap at 100)
GET {{baseUrl}}/founders?page=1&pageSize=500
Authorization: {{authToken}}
Content-Type: application/json

### Test 37: No Pagination Params (should use defaults)
GET {{baseUrl}}/founders
Authorization: {{authToken}}
Content-Type: application/json

### Test 38: Invalid Page Size (0)
GET {{baseUrl}}/founders?page=1&pageSize=0
Authorization: {{authToken}}
Content-Type: application/json

### Test 39: Invalid Page Size (Negative)
GET {{baseUrl}}/founders?page=1&pageSize=-10
Authorization: {{authToken}}
Content-Type: application/json

### ============================================
### PERFORMANCE & METRICS VALIDATION
### ============================================

### Test 40: Cache Test - Same Request Twice (should be faster 2nd time)
# First request
GET {{baseUrl}}/founders?page=1&pageSize=10
Authorization: {{authToken}}
Content-Type: application/json

### Test 41: Cache Test - Second Request (check response time)
GET {{baseUrl}}/founders?page=1&pageSize=10
Authorization: {{authToken}}
Content-Type: application/json

### Test 42: Large Dataset Test
GET {{baseUrl}}/talent/browse?page=1&pageSize=100
Authorization: {{authToken}}
Content-Type: application/json

### ============================================
### RESPONSE STRUCTURE VALIDATION
### ============================================
# All responses should include:
# {
#   "success": true,
#   "items": [...],  // or "tasks", "milestones", etc.
#   "pagination": {
#     "total": number,
#     "page": number,
#     "pageSize": number,
#     "totalPages": number,
#     "hasNext": boolean,
#     "hasPrev": boolean
#   }
# }

### ============================================
### NOTES
### ============================================
# 1. Replace all {placeholders} with actual IDs from your database
# 2. Update {{projectId}} and {{publicAnonKey}} at the top
# 3. Check response times - should be <500ms for cached, <1000ms for fresh
# 4. Verify pagination object structure in all responses
# 5. Confirm cache hit rates increase on repeated requests
# 6. Check server logs for performance metrics
